# Root .gitignore for the whole repository

# OS
.DS_Store
Thumbs.db

# IDE/Editor
.idea/
.vscode/
*.iml

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment files (all locations)
.env
.env.*
**/.env
**/.env.*

# Node / Monorepo
node_modules/
**/node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# TypeScript
*.tsbuildinfo

# Build outputs
dist/
build/
coverage/

# Next.js
.next/
**/.next/
out/
**/out/
next-env.d.ts

# Vercel
.vercel

# Contracts (Hardhat)
contracts/artifacts/
contracts/cache/
contracts/deployments/

# Go (backend)
Blockchain-backend/server
Blockchain-backend/*.exe
Blockchain-backend/*.out

# Docker/Compose overrides
docker-compose.override.yml

# Misc
*.pem
/contracts/.pnpm-store/
